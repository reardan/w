void clang_advance_position(char* input, int start, int length, int* linep, int* columnp):
	int i = 0
	while (i < length):
		if (input[start + i] == 10):
			linep[0] = linep[0] + 1
			columnp[0] = 1
		else:
			columnp[0] = columnp[0] + 1
		i = i + 1

