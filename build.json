				{"cmd": ["bin/wv2", "--bounds=off", "tests/range_bounds_trap_test.w", "-o", "bin/range_bounds_trap_test_off"]}
			]
		},
		{
			"name": "buffer_field_assign_test",
			"deps": ["wv2"],
			"steps": [
				{
					"cmd": ["bin/wv2", "tests/buffer_field_assign_test.w", "-o", "bin/buffer_field_assign_test"],
					"expect_fail": true,
					"expect_stderr": "cannot assign to read-only buffer field"
				}
			]
		},
		{
			"name": "array_error_test",
			"deps": ["wv2"],
			"steps": [
				{
					"cmd": ["bin/wv2", "tests/array_param_error_fixture.w", "-o", "bin/array_param_error_fixture"],
					"expect_fail": true,
					"expect_stderr": "fixed array parameter is not implemented; use T[] instead"
				},
				{
					"cmd": ["bin/wv2", "tests/array_union_error_fixture.w", "-o", "bin/array_union_error_fixture"],
					"expect_fail": true,
					"expect_stderr": "fixed array fields are not implemented in unions"
				},
				{
					"cmd": ["bin/wv2", "tests/array_constructor_error_fixture.w", "-o", "bin/array_constructor_error_fixture"],
					"expect_fail": true,
					"expect_stderr": "cannot initialize fixed-array field in constructor"
				}
			]
		},
		{
			"name": "warning_test",
			"deps": ["wv2"],
			"steps": [
				{
					"cmd": ["bin/wv2", "tests/warning_fixture.w", "-o", "bin/warning_fixture"],
					"expect_stderr": [
						"warning: assignment type mismatch: expected 'char*', got 'int*'",
						"warning: assignment type mismatch: expected 'char*', got 'char**'",
						"warning: initialization type mismatch: expected 'int*', got 'char*'",
						"warning: function 'takes_char_ptr' argument 1 type mismatch: expected 'char*', got 'int*'",
						"warning: return type mismatch: expected 'char*', got 'int*'",
						"warning: assignment type mismatch: expected 'pair', got 'single'",
						"warning: assignment type mismatch: expected 'char*', got 'int'",
						"warning: assignment type mismatch: expected 'int', got 'char*'",
						"warning: function 'takes_char_ptr' argument 1 type mismatch: expected 'char*', got 'int'",
						"warning: return type mismatch: expected 'char*', got 'int'",
						"warning: initialization type mismatch: expected 'char*', got 'function'",
						"warning: assignment type mismatch: expected 'int', got 'function'",
						"warning: line indented with spaces instead of tabs",
						"warning: file does not end with a newline"
					]
				},
				{
					"cmd": ["bin/wv2", "tests/warning_clean_fixture.w", "-o", "bin/warning_clean_fixture"],
					"reject_stderr": "warning:"
				},
				{
					"cmd": ["bin/wv2", "tests/string_char_warning_fixture.w", "-o", "bin/string_char_warning_fixture"],
					"expect_stderr": [
						"warning: return type mismatch: expected 'char*', got 'string value'",
						"warning: initialization type mismatch: expected 'char*', got 'string value'",
						"warning: function 'takes_char_ptr' argument 1 type mismatch: expected 'char*', got 'string value'",
						"warning: assignment type mismatch: expected 'char*', got 'string value'"
					]
				}
			]
		},
		{
			"name": "check_json_test",
			"deps": ["wv2"],
			"steps": [
				{
					"cmd": ["bin/wv2", "check", "--json", "tests/warning_fixture.w"],
					"stdout_file": "bin/check_json_warning.ndjson",
					"expect_stdout": [
						"\"severity\": \"warning\"",
						"\"file\": \"/workspace/tests/warning_fixture.w\"",
						"\"message\": \"assignment type mismatch: expected 'char*', got 'int*'\"",
						"\"token\":",
						"\"arch\": \"x86\""
					]
				},
				{"cmd": ["grep", "-qE", "\"line\": [1-9][0-9]*", "bin/check_json_warning.ndjson"]},
				{"cmd": ["grep", "-qE", "\"column\": [1-9][0-9]*", "bin/check_json_warning.ndjson"]},
				{
					"cmd": ["bin/wv2", "check", "--json", "tests/type_system_error_fixture.w"],
					"expect_fail": true,
					"expect_stdout": [
						"\"severity\": \"error\"",
						"\"message\": \"assignment to const\""
					]
				},
				{
					"cmd": ["bin/wv2", "check", "--json", "tests/warning_clean_fixture.w"],
					"stdout_file": "bin/check_json_clean.ndjson"
				},
				{"cmd": ["test", "!", "-s", "bin/check_json_clean.ndjson"]},
				{
					"cmd": ["bin/wv2", "check", "--json", "x64", "tests/warning_fixture.w"],
					"expect_stdout": "\"arch\": \"x64\""
				}
			]
		},
		{
			"name": "symbols_test",
			"deps": ["wv2"],
			"steps": [
				{
					"cmd": ["bin/wv2", "symbols", "--json", "tests/symbols_fixture.w"],
					"stdout_file": "bin/symbols_fixture.ndjson",
					"expect_stdout": [
						"\"name\": \"sym_fixture_add\", \"kind\": \"function\", \"type\": \"int\"",
						"\"name\": \"sym_fixture_counter\", \"kind\": \"object\", \"type\": \"int\"",
						"\"name\": \"sym_fixture_point\", \"kind\": \"struct\", \"type\": \"sym_fixture_point\"",
						"\"name\": \"sym_fixture_size\", \"kind\": \"alias\"",
						"\"name\": \"sym_fixture_color\", \"kind\": \"enum\"",
						"\"arch\": \"x86\""
					]
				},
				{"cmd": ["grep", "-qE", "\"name\": \"sym_fixture_add\".*\"file\": \"[^\"]*tests/symbols_fixture.w\", \"line\": 11, \"column\": 5", "bin/symbols_fixture.ndjson"]},
				{"cmd": ["grep", "-qE", "\"name\": \"sym_fixture_red\".*\"line\": 18, \"column\": 2", "bin/symbols_fixture.ndjson"]},
				{"cmd": ["grep", "-qE", "\"name\": \"sym_fixture_green\".*\"line\": 19, \"column\": 2", "bin/symbols_fixture.ndjson"]},
				{
					"cmd": ["bin/wv2", "symbols", "tests/symbols_fixture.w"],
					"expect_stdout": "tests/symbols_fixture.w:11:5: function sym_fixture_add: int"
				},
				{
					"cmd": ["bin/wv2", "symbols", "--json", "x64", "tests/symbols_fixture.w"],
					"expect_stdout": [
						"\"arch\": \"x64\"",
						"\"name\": \"sym_fixture_add\", \"kind\": \"function\", \"type\": \"int\""
					]
				}
			]
		},
