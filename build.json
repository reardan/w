{
	"dirs": ["bin"],
	"targets": [
		{
			"name": "wv2",
			"steps": [
				{"cmd": ["./w", "w.w", "-o", "bin/wv2"]}
			]
		},
		{
			"name": "wexec",
			"deps": ["wv2"],
			"steps": [
				{"cmd": ["bin/wv2", "tools/wexec.w", "-o", "bin/wexec.stage"]},
				{"cmd": ["mv", "bin/wexec.stage", "bin/wexec"]}
			]
		},
		{
			"name": "build",
			"deps": ["wv2"],
			"steps": [
				{"cmd": ["bin/wv2", "w.w", "-o", "bin/wv3"]},
				{"cmd": ["bin/wv3", "w.w", "-o", "bin/wv4"]},
				{"cmd": ["bin/wv4", "w.w", "-o", "bin/wv5"]}
			]
		},
		{
			"name": "verify",
			"deps": ["build"],
			"steps": [
				{"cmd": ["cmp", "bin/wv3", "bin/wv4"]},
				{"cmd": ["cmp", "bin/wv4", "bin/wv5"]},
				{"cmd": ["echo", "self-host fixpoint OK: wv3 == wv4 == wv5"]}
			]
		},
		{
			"name": "hello",
			"deps": ["wv2"],
			"steps": [
				{"cmd": ["bin/wv2", "tests/hello.w", "-o", "bin/hello"]},
				{"cmd": ["bin/hello"], "expect_stdout": "hello, world!"}
			]
		},
		{
			"name": "test",
			"deps": ["wv2"],
			"steps": [
				{"cmd": ["bin/wv2", "tests/test.w", "-o", "bin/test"]},
				{"cmd": ["bin/test"]}
			]
		},
		{
			"name": "lib_test",
			"deps": ["wv2"],
			"steps": [
				{"cmd": ["bin/wv2", "lib/lib_test.w", "-o", "bin/lib_test"]},
				{"cmd": ["bin/lib_test"]}
			]
		},
		{
			"name": "x64_test",
			"deps": ["wv2"],
			"steps": [
				{"cmd": ["bin/wv2", "x64", "tests/x64_test.w", "-o", "bin/x64_test"]},
				{"cmd": ["bin/x64_test"]}
			]
		},
		{
			"name": "dynamic_test",
			"deps": ["wv2"],
			"steps": [
				{"cmd": ["bin/wv2", "tests/dynamic_test.w", "-o", "bin/dynamic_test"]},
				{"cmd": ["bin/dynamic_test"], "expect_stdout": "dynamic linking OK"}
			]
		},
		{
			"name": "float_abi_test",
			"deps": ["wv2"],
			"steps": [
				{"cmd": ["bin/wv2", "tests/float_abi_test.w", "-o", "bin/float_abi_test"]},
				{"cmd": ["bin/float_abi_test"], "expect_stdout": "float abi OK"}
			]
		},
		{
			"name": "varargs_test",
			"deps": ["wv2"],
			"steps": [
				{"cmd": ["bin/wv2", "tests/varargs_test.w", "-o", "bin/varargs_test"]},
				{"cmd": ["bin/varargs_test"], "expect_stdout": "varargs OK"}
			]
		},
		{
			"name": "extern_data_test",
			"deps": ["wv2"],
			"steps": [
				{"cmd": ["bin/wv2", "tests/extern_data_test.w", "-o", "bin/extern_data_test"]},
				{"cmd": ["bin/extern_data_test"], "expect_stdout": "extern data OK"}
			]
		},
		{
			"name": "int64_x86_error_test",
			"deps": ["wv2"],
			"steps": [
				{
					"cmd": ["bin/wv2", "tests/x64_int64_test.w", "-o", "bin/int64_x86_error_test"],
					"expect_fail": true,
					"expect_stderr": "int64 requires the x64 target"
				}
			]
		},
		{
			"name": "wdbg",
			"deps": ["wv2"],
			"steps": [
				{"cmd": ["bin/wv2", "debugger/debugger.w", "-o", "bin/wdbg"]}
			]
		},
		{
			"name": "tests",
			"deps": [
				"verify",
				"hello",
				"test",
				"lib_test",
				"x64_test",
				"dynamic_test",
				"float_abi_test",
				"varargs_test",
				"extern_data_test",
				"int64_x86_error_test",
				"wdbg",
				"wexec"
			]
		}
	]
}
