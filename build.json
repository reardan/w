				{"cmd": ["bin/string_utf8_test"]},
				{
					"cmd": ["bin/wv2", "tests/string_utf8_invalid_fixture.w", "-o", "bin/string_utf8_invalid_fixture"],
					"expect_fail": true,
					"expect_stderr": "invalid UTF-8 string literal"
				},
				{"cmd": ["bin/wv2", "tests/string_utf8_invalid_cstr_fixture.w", "-o", "bin/string_utf8_invalid_cstr_fixture"]},
				{
					"cmd": ["bin/string_utf8_invalid_cstr_fixture"],
					"expect_fail": true,
					"expect_stderr": "invalid UTF-8 c string"
				},
				{"cmd": ["bin/wv2", "tests/string_utf8_invalid_cstr_arg_fixture.w", "-o", "bin/string_utf8_invalid_cstr_arg_fixture"]},
				{
					"cmd": ["bin/string_utf8_invalid_cstr_arg_fixture"],
					"expect_fail": true,
					"expect_stderr": "invalid UTF-8 c string"
				}
			]
		},
		{
			"name": "grapheme_test",
			"deps": ["wv2"],
			"steps": [
				{"cmd": ["bin/wv2", "tests/grapheme_test.w", "-o", "bin/grapheme_test"]},
				{"cmd": ["bin/grapheme_test"]}
			]
		},
		{
			"name": "bounds_trap_test",
			"deps": ["wv2"],
			"steps": [
				{"cmd": ["bin/wv2", "tests/bounds_trap_test.w", "-o", "bin/bounds_trap_test"]},
				{"cmd": ["bin/bounds_trap_test"], "expect_fail": true},
				{"cmd": ["bin/wv2", "--bounds=off", "tests/bounds_trap_test.w", "-o", "bin/bounds_trap_test_off"]}
			]
		},
		{
			"name": "range_bounds_trap_test",
			"deps": ["wv2"],
			"steps": [
				{"cmd": ["bin/wv2", "tests/range_bounds_trap_test.w", "-o", "bin/range_bounds_trap_test"]},
