{
	"dirs": ["bin"],
	"targets": [
		{
			"name": "wv2",
			"inputs": ["w.w", "compiler/", "grammar/", "code_generator/", "lib/", "structures/", "libs/", "debugger/"],
			"outputs": ["bin/wv2"],
			"steps": [
				{"cmd": ["./w", "w.w", "-o", "bin/wv2"]}
			]
		},
		{
			"name": "wexec",
			"deps": ["wv2"],
			"inputs": ["tools/wexec.w"],
			"outputs": ["bin/wexec"],
			"steps": [
				{"cmd": ["bin/wv2", "tools/wexec.w", "-o", "bin/wexec.stage"]},
				{"cmd": ["mv", "bin/wexec.stage", "bin/wexec"]}
			]
		},
		{
			"name": "build",
			"deps": ["wv2"],
			"inputs": [],
			"outputs": ["bin/wv3", "bin/wv4", "bin/wv5"],
			"steps": [
				{"cmd": ["bin/wv2", "w.w", "-o", "bin/wv3"]},
				{"cmd": ["bin/wv3", "w.w", "-o", "bin/wv4"]},
				{"cmd": ["bin/wv4", "w.w", "-o", "bin/wv5"]}
			]
		},
		{
			"name": "verify",
			"deps": ["build"],
			"inputs": [],
			"steps": [
				{"cmd": ["cmp", "bin/wv3", "bin/wv4"]},
				{"cmd": ["cmp", "bin/wv4", "bin/wv5"]},
				{"cmd": ["echo", "self-host fixpoint OK: wv3 == wv4 == wv5"]}
			]
		},
		{
			"name": "hello",
			"deps": ["wv2"],
			"steps": [
				{"cmd": ["bin/wv2", "tests/hello.w", "-o", "bin/hello"]},
				{"cmd": ["bin/hello"], "expect_stdout": "hello, world!"}
			]
		},
		{
			"name": "test",
			"deps": ["wv2"],
			"steps": [
				{"cmd": ["bin/wv2", "tests/test.w", "-o", "bin/test"]},
				{"cmd": ["bin/test"]}
			]
		},
		{
			"name": "lib_test",
			"deps": ["wv2"],
			"steps": [
				{"cmd": ["bin/wv2", "lib/lib_test.w", "-o", "bin/lib_test"]},
				{"cmd": ["bin/lib_test"]}
			]
		},
		{
			"name": "path_test",
			"deps": ["wv2"],
			"steps": [
				{"cmd": ["bin/wv2", "lib/path_test.w", "-o", "bin/path_test"]},
				{"cmd": ["bin/path_test"]}
			]
		},
		{
			"name": "grammar_test",
