			]
		},
		{
			"name": "float_reference_test",
			"deps": ["wv2"],
			"steps": [
				{"cmd": ["cc", "-std=c99", "-O0", "-fno-fast-math", "tests/float_reference.c", "-o", "bin/float_reference_c"]},
				{"cmd": ["bin/float_reference_c", "f32"], "stdout_file": "bin/float_reference_c32.out"},
				{"cmd": ["bin/wv2", "tests/float_reference.w", "-o", "bin/float_reference_w32"]},
				{"cmd": ["bin/float_reference_w32"], "stdout_file": "bin/float_reference_w32.out"},
				{"cmd": ["diff", "-u", "bin/float_reference_c32.out", "bin/float_reference_w32.out"]},
				{"cmd": ["bin/float_reference_c", "f64"], "stdout_file": "bin/float_reference_c64.out"},
				{"cmd": ["bin/wv2", "x64", "tests/x64_float_reference.w", "-o", "bin/float_reference_w64"]},
				{"cmd": ["bin/float_reference_w64"], "stdout_file": "bin/float_reference_w64.out"},
				{"cmd": ["diff", "-u", "bin/float_reference_c64.out", "bin/float_reference_w64.out"]}
			]
		},
		{
			"name": "array_slice_string_test",
			"deps": ["wv2"],
			"steps": [
				{"cmd": ["bin/wv2", "tests/array_slice_string_test.w", "-o", "bin/array_slice_string_test"]},
				{"cmd": ["bin/array_slice_string_test"]}
			]
		},
