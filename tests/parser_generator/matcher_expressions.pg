parser matcher_expr

fragment HEXNUM = HASH_PREFIX HEXDIGIT+
fragment HASH_PREFIX = "#" ("x" | "X")
fragment HEXDIGIT = [0-9a-fA-F]
fragment DECNUM = [0-9]+
fragment CHAR = "'" [^'\r\n] "'"

skip DASH_COMMENT = "--" [^\r\n]*

token TIE_FIRST = "@"
token TIE_SECOND = "@"
token SHORT = "ab"
token LONG = "abc"
token ALT = "z" | "zoom"
token DIGITS digits
token SIGNED = ("+" | "-") DIGITS
token PREFIX = "pre"
token PREFIXED = PREFIX [0-9]+
token NUMCONST = DECNUM | HEXNUM | CHAR
token IDENT = [a-zA-Z_] [a-zA-Z0-9_-]*
token NEWLINE_TOK = "\r"? "\n"

# Dispatch-table lexer edge cases: literals sharing a first byte compile
# to a comparison trie ("<" vs "<<=" checks prefix fallback), and an
# identifier-shaped literal must still beat an equal-length token match
# ("zoo" vs IDENT) while losing to a longer one ("zoom" via ALT).
literal LT "<"
literal SHL_ASSIGN "<<="
literal KW_ZOO "zoo"

start input

rule input = EOF
