parser clang

skip C_PREPROCESSOR c_preprocessor
skip LINE_COMMENT c_line_comment
skip BLOCK_COMMENT block_comment
skip C_CONTROL c_control
skip NEWLINE newline
skip TAB tabs

token STRING c_string
token CHAR_LITERAL c_char_literal
token NUMBER c_number
token IDENT identifier

literal KW_TYPEDEF "typedef"
literal KW_EXTERN "extern"
literal KW_STATIC "static"
literal KW_AUTO "auto"
literal KW_REGISTER "register"
literal KW_INLINE "inline"
literal KW_CONST "const"
literal KW_RESTRICT "restrict"
literal KW_VOLATILE "volatile"
literal KW_VOID "void"
literal KW_CHAR "char"
literal KW_SHORT "short"
literal KW_INT "int"
literal KW_LONG "long"
literal KW_FLOAT "float"
literal KW_DOUBLE "double"
literal KW_SIGNED "signed"
literal KW_UNSIGNED "unsigned"
literal KW_STRUCT "struct"
literal KW_UNION "union"
literal KW_ENUM "enum"
literal KW_SIZEOF "sizeof"
literal KW_RETURN "return"
literal KW_IF "if"
literal KW_ELSE "else"
literal KW_WHILE "while"
literal KW_DO "do"
literal KW_FOR "for"
literal KW_SWITCH "switch"
literal KW_CASE "case"
literal KW_DEFAULT "default"
literal KW_BREAK "break"
literal KW_CONTINUE "continue"
literal KW_GOTO "goto"

literal ELLIPSIS "..."
literal SHIFT_LEFT_ASSIGN "<<="
literal SHIFT_RIGHT_ASSIGN ">>="
literal PLUS_PLUS "++"
literal MINUS_MINUS "--"
literal ARROW "->"
literal SHIFT_LEFT "<<"
literal SHIFT_RIGHT ">>"
literal LT_EQ "<="
literal GT_EQ ">="
literal EQ_EQ "=="
literal BANG_EQ "!="
literal AND_AND "&&"
literal OR_OR "||"
literal PLUS_ASSIGN "+="
literal MINUS_ASSIGN "-="
literal STAR_ASSIGN "*="
literal SLASH_ASSIGN "/="
literal PERCENT_ASSIGN "%="
literal AMP_ASSIGN "&="
literal CARET_ASSIGN "^="
literal PIPE_ASSIGN "|="
literal PLUS "+"
literal MINUS "-"
literal STAR "*"
literal SLASH "/"
literal PERCENT "%"
literal AMP "&"
literal PIPE "|"
literal CARET "^"
literal BANG "!"
literal TILDE "~"
literal ASSIGN "="
literal LT "<"
literal GT ">"
literal QUESTION "?"
literal COLON ":"
literal SEMI ";"
literal COMMA ","
literal DOT "."
literal LPAREN "("
literal RPAREN ")"
literal LBRACK "["
literal RBRACK "]"
literal LBRACE "{"
literal RBRACE "}"

start translation_unit

rule translation_unit = external_declaration* EOF
rule external_declaration = declaration | function_definition | declaration_annotation | SEMI

rule declaration = typedef_name_declaration_specifiers init_declarator_list declaration_annotation* SEMI | declaration_specifiers init_declarator_list? declaration_annotation* SEMI
rule declaration_specifiers = declaration_specifier+
rule declaration_specifier = storage_class_specifier | type_specifier | type_qualifier | function_specifier
rule typedef_name_declaration_specifiers = typedef_name_declaration_prefix* typedef_name_specifier typedef_name_declaration_suffix*
rule typedef_name_declaration_prefix = storage_class_specifier | type_qualifier | function_specifier
rule typedef_name_declaration_suffix = type_qualifier | function_specifier
rule storage_class_specifier = KW_TYPEDEF | KW_EXTERN | KW_STATIC | KW_AUTO | KW_REGISTER
rule function_specifier = KW_INLINE
rule type_qualifier = KW_CONST | KW_RESTRICT | KW_VOLATILE
rule type_specifier = primitive_type | struct_or_union_specifier | enum_specifier
rule typedef_name_specifier = IDENT
rule primitive_type = KW_VOID | KW_CHAR | KW_SHORT | KW_INT | KW_LONG | KW_FLOAT | KW_DOUBLE | KW_SIGNED | KW_UNSIGNED
rule declaration_annotation = IDENT declaration_annotation_args?
rule declaration_annotation_args = LPAREN declaration_annotation_item* RPAREN
rule declaration_annotation_item = declaration_annotation_args | IDENT | NUMBER | STRING | CHAR_LITERAL | COMMA

rule init_declarator_list = init_declarator init_declarator_tail*
rule init_declarator_tail = COMMA init_declarator
rule init_declarator = declarator initializer_part?
rule initializer_part = ASSIGN initializer
rule initializer = assignment_expression | LBRACE initializer_list? initializer_comma? RBRACE
rule initializer_list = initializer_item initializer_tail*
rule initializer_tail = COMMA initializer_item
rule initializer_item = designation? initializer
rule initializer_comma = COMMA
rule designation = designator+ ASSIGN
rule designator = LBRACK constant_expression RBRACK | DOT IDENT

rule struct_or_union_specifier = struct_or_union IDENT struct_body | struct_or_union struct_body | struct_or_union IDENT
rule struct_or_union = KW_STRUCT | KW_UNION
rule struct_body = LBRACE struct_declaration* RBRACE
rule struct_declaration = typedef_name_specifier_qualifier_list struct_declarator_list? SEMI | specifier_qualifier_list struct_declarator_list? SEMI
rule specifier_qualifier_list = specifier_qualifier+
rule specifier_qualifier = type_specifier | type_qualifier
rule typedef_name_specifier_qualifier_list = type_qualifier* typedef_name_specifier type_qualifier*
rule struct_declarator_list = struct_declarator struct_declarator_tail*
rule struct_declarator_tail = COMMA struct_declarator
rule struct_declarator = declarator bit_field? | bit_field
rule bit_field = COLON constant_expression

rule enum_specifier = KW_ENUM IDENT enum_body | KW_ENUM enum_body | KW_ENUM IDENT
rule enum_body = LBRACE enumerator_list? enum_comma? RBRACE
rule enumerator_list = enumerator enumerator_tail*
rule enumerator_tail = COMMA enumerator
rule enum_comma = COMMA
rule enumerator = IDENT enum_value?
rule enum_value = ASSIGN constant_expression

rule declarator = pointer? direct_declarator
rule direct_declarator = IDENT direct_declarator_tail* | LPAREN declarator RPAREN direct_declarator_tail*
rule direct_declarator_tail = LBRACK constant_expression? RBRACK | LPAREN parameter_type_list? RPAREN | LPAREN identifier_list? RPAREN
rule pointer = STAR type_qualifier_list? pointer?
rule type_qualifier_list = type_qualifier+
rule identifier_list = IDENT identifier_tail*
rule identifier_tail = COMMA IDENT

rule parameter_type_list = parameter_list parameter_ellipsis?
rule parameter_ellipsis = COMMA ELLIPSIS
rule parameter_list = parameter_declaration parameter_tail*
rule parameter_tail = COMMA parameter_declaration
rule parameter_declaration = typedef_name_declaration_specifiers parameter_declarator? | declaration_specifiers parameter_declarator?
rule parameter_declarator = declarator | abstract_declarator

rule type_name = typedef_name_specifier_qualifier_list abstract_declarator? | specifier_qualifier_list abstract_declarator?
rule abstract_declarator = pointer? direct_abstract_declarator | pointer
rule direct_abstract_declarator = LPAREN abstract_declarator RPAREN direct_abstract_declarator_tail* | direct_abstract_declarator_tail+
rule direct_abstract_declarator_tail = LBRACK constant_expression? RBRACK | LPAREN parameter_type_list? RPAREN

rule function_definition = declaration_specifiers declarator compound_statement | typedef_name_declaration_specifiers declarator compound_statement
rule compound_statement = LBRACE block_item* RBRACE
rule block_item = declaration | statement
rule statement = compound_statement | if_statement | while_statement | do_statement | for_statement | switch_statement | return_statement | break_statement | continue_statement | goto_statement | labeled_statement | expression_statement
rule if_statement = KW_IF LPAREN expression RPAREN statement else_part?
rule else_part = KW_ELSE statement
rule while_statement = KW_WHILE LPAREN expression RPAREN statement
rule do_statement = KW_DO statement KW_WHILE LPAREN expression RPAREN SEMI
rule for_statement = KW_FOR LPAREN for_init expression? SEMI expression? RPAREN statement
rule for_init = declaration | expression_statement
rule switch_statement = KW_SWITCH LPAREN expression RPAREN statement
rule labeled_statement = KW_CASE constant_expression COLON statement | KW_DEFAULT COLON statement | IDENT COLON statement
rule break_statement = KW_BREAK SEMI
rule continue_statement = KW_CONTINUE SEMI
rule goto_statement = KW_GOTO IDENT SEMI
rule return_statement = KW_RETURN expression? SEMI
rule expression_statement = expression? SEMI

rule constant_expression = conditional_expression
rule expression = assignment_expression expression_tail*
rule expression_tail = COMMA assignment_expression
rule assignment_expression = unary_expression assignment_operator assignment_expression | conditional_expression
rule assignment_operator = ASSIGN | STAR_ASSIGN | SLASH_ASSIGN | PERCENT_ASSIGN | PLUS_ASSIGN | MINUS_ASSIGN | SHIFT_LEFT_ASSIGN | SHIFT_RIGHT_ASSIGN | AMP_ASSIGN | CARET_ASSIGN | PIPE_ASSIGN
rule conditional_expression = binary_expression conditional_tail?
rule conditional_tail = QUESTION expression COLON conditional_expression
rule binary_expression = unary_expression binary_tail*
rule binary_tail = binary_operator unary_expression
rule binary_operator = OR_OR | AND_AND | PIPE | CARET | AMP | EQ_EQ | BANG_EQ | LT_EQ | GT_EQ | LT | GT | SHIFT_LEFT | SHIFT_RIGHT | PLUS | MINUS | STAR | SLASH | PERCENT
rule unary_expression = cast_expression | postfix_expression | unary_operator unary_expression | KW_SIZEOF LPAREN type_name RPAREN | KW_SIZEOF unary_expression
rule cast_expression = LPAREN cast_type_name RPAREN unary_expression
rule cast_type_name = specifier_qualifier_list abstract_declarator? | typedef_name_specifier_qualifier_list abstract_declarator
rule unary_operator = AMP | STAR | PLUS | MINUS | TILDE | BANG
rule postfix_expression = primary_expression postfix_tail*
rule postfix_tail = LBRACK expression RBRACK | LPAREN argument_expression_list? RPAREN | DOT IDENT | ARROW IDENT | PLUS_PLUS | MINUS_MINUS
rule argument_expression_list = assignment_expression argument_tail*
rule argument_tail = COMMA assignment_expression
rule primary_expression = IDENT | NUMBER | STRING | CHAR_LITERAL | LPAREN expression RPAREN
