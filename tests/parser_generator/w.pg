parser wlang

skip LINE_COMMENT line_comment
skip BLOCK_COMMENT block_comment

token NEWLINE newline
token TAB tabs
# STRING covers plain "...", prefixed s"..."/c"..." and whole f"..."
# template strings (embedded {expression} parts included, see
# pg_lexer_match_template_string in libs/extras/parser_generator/lexer.w)
token STRING string
token CHAR_LITERAL char_literal
token NUMBER number
token IDENT identifier

literal KW_IMPORT "import"
literal KW_AS "as"
literal KW_STRUCT "struct"
literal KW_UNION "union"
literal KW_ENUM "enum"
literal KW_TYPE "type"
literal KW_EXTERN "extern"
literal KW_C_LIB "c_lib"
literal KW_IF "if"
literal KW_ELSE "else"
literal KW_WHILE "while"
literal KW_FOR "for"
literal KW_IN "in"
literal KW_RANGE "range"
literal KW_RETURN "return"
literal KW_BREAK "break"
literal KW_CONTINUE "continue"
literal KW_PASS "pass"
literal KW_DEBUGGER "debugger"
literal KW_NEW "new"
literal KW_CONST "const"
literal KW_INT "int"
literal KW_CHAR "char"
literal KW_VOID "void"
literal KW_STRING "string"
literal KW_ASM "asm"
literal KW_INLINE "inline"
literal KW_FN "fn"
literal KW_BOOL "bool"
literal KW_UINT "uint"
literal KW_CAST "cast"
literal KW_TRUE "true"
literal KW_FALSE "false"
literal KW_MAP "map"
literal KW_SET "set"
literal KW_LIST "list"
literal KW_GENERATOR "generator"
literal KW_YIELD "yield"
literal KW_VAR "var"
literal KW_SWITCH "switch"
# 'case' and 'default' are contextual keywords in the compiler (only
# recognized as clause labels inside a switch body). The PG lexer always
# tokenizes them as keywords, so they are also listed in name_token to
# keep them usable as ordinary identifiers, and case_stmt is just
# another statement alternative (PG is syntax-only and permissive).
literal KW_CASE "case"
literal KW_DEFAULT "default"

literal ELLIPSIS "..."
literal AND_AND "&&"
literal OR_OR "||"
literal EQ_EQ "=="
literal BANG_EQ "!="
literal LT_EQ "<="
literal GT_EQ ">="
literal SHIFT_LEFT "<<"
literal SHIFT_RIGHT ">>"
literal ARROW "->"
literal PLUS "+"
literal MINUS "-"
literal STAR "*"
literal SLASH "/"
literal PERCENT "%"
literal LT "<"
literal GT ">"
literal AMP "&"
literal PIPE "|"
literal BANG "!"
literal ASSIGN "="
literal DOT "."
literal COMMA ","
literal COLON ":"
literal SEMI ";"
literal LPAREN "("
literal RPAREN ")"
literal LBRACK "["
literal RBRACK "]"
literal LBRACE "{"
literal RBRACE "}"

start program

# On a top-level syntax error, report a diagnostic and resynchronize at the
# next line that starts at tab level zero (skipping blank and indented lines).
recover top_item NEWLINE TAB

rule program = separator* top_item* EOF
rule separator = NEWLINE
rule top_item = declaration separator* | statement separator*

rule declaration = import_decl | c_lib_decl | extern_decl | inline_asm_decl | asm_decl | struct_decl | union_decl | enum_decl | type_alias_decl | generator_decl | function_decl | global_decl
rule import_decl = KW_IMPORT dotted_name import_alias_opt
rule import_alias_opt = KW_AS name_token |
rule dotted_name = name_token dotted_tail*
rule dotted_tail = DOT name_token
rule name_token = IDENT | KW_AS | KW_IMPORT | KW_STRUCT | KW_UNION | KW_ENUM | KW_TYPE | KW_EXTERN | KW_C_LIB | KW_IF | KW_ELSE | KW_WHILE | KW_FOR | KW_IN | KW_RANGE | KW_RETURN | KW_BREAK | KW_CONTINUE | KW_PASS | KW_DEBUGGER | KW_NEW | KW_CONST | KW_INT | KW_CHAR | KW_VOID | KW_STRING | KW_ASM | KW_INLINE | KW_FN | KW_BOOL | KW_UINT | KW_CAST | KW_TRUE | KW_FALSE | KW_MAP | KW_SET | KW_LIST | KW_GENERATOR | KW_YIELD | KW_VAR | KW_SWITCH | KW_CASE | KW_DEFAULT
rule c_lib_decl = KW_C_LIB STRING
rule extern_decl = KW_EXTERN type_ref IDENT LPAREN extern_param_list RPAREN | KW_EXTERN type_ref IDENT
rule extern_param_list = param extern_param_tail* | ELLIPSIS |
rule extern_param_tail = COMMA ELLIPSIS | COMMA param
rule inline_asm_decl = KW_INLINE KW_ASM type_ref STRING LPAREN param_list RPAREN asm_body
rule asm_decl = KW_ASM name_token LPAREN asm_param_list RPAREN asm_body
rule asm_param_list = name_token asm_param_tail* |
rule asm_param_tail = COMMA name_token
rule asm_body = COLON asm_body_lines
rule asm_body_lines = asm_body_line asm_body_lines |
rule asm_body_line = NEWLINE tab_prefix asm_tokens | NEWLINE
rule asm_tokens = asm_token asm_tokens |
rule asm_token = name_token | NUMBER | STRING | CHAR_LITERAL | ELLIPSIS | AND_AND | OR_OR | EQ_EQ | BANG_EQ | LT_EQ | GT_EQ | SHIFT_LEFT | SHIFT_RIGHT | ARROW | PLUS | MINUS | STAR | SLASH | PERCENT | LT | GT | AMP | PIPE | BANG | ASSIGN | DOT | COMMA | COLON | SEMI | LPAREN | RPAREN | LBRACK | RBRACK | LBRACE | RBRACE
rule struct_decl = KW_STRUCT IDENT generic_opt block
rule union_decl = KW_UNION IDENT block
rule enum_decl = KW_ENUM IDENT block
rule type_alias_decl = KW_TYPE IDENT ASSIGN type_ref
rule generator_decl = KW_GENERATOR type_ref name_token LPAREN param_list RPAREN function_body
rule function_decl = type_ref name_token generic_opt LPAREN param_list RPAREN function_body
rule global_decl = type_ref name_token decl_suffix global_suffix
rule global_suffix = ASSIGN expression | SEMI | 
rule function_body = SEMI | block
rule decl_suffix = LBRACK expression RBRACK |

rule block = COLON statement | COLON block_body | LBRACE brace_body RBRACE
rule block_body = block_line block_body | 
rule block_line = NEWLINE tab_prefix statement | NEWLINE tab_prefix | NEWLINE
rule brace_body = brace_line brace_body |
rule brace_line = NEWLINE tab_prefix statement | NEWLINE tab_prefix | NEWLINE | statement
rule tab_prefix = TAB tab_prefix | TAB

rule param_list = param param_tail* | 
rule param_tail = COMMA param
rule param = type_ref ELLIPSIS name_token | type_ref name_token decl_suffix param_default | type_ref
rule param_default = ASSIGN expression |

rule type_ref = KW_CONST type_ref | fn_type pointer_part* array_part* | map_type pointer_part* array_part* | set_type pointer_part* array_part* | list_type pointer_part* array_part* | type_atom generic_opt pointer_part* array_part*
# Generics ([T] parameter lists on definitions, [int] argument lists at
# instantiation sites). Permissive: type_ref covers both bare parameter
# names and concrete argument types; PG is syntax-only.
rule generic_opt = generic_args |
rule generic_args = LBRACK type_ref generic_arg_tail* RBRACK
rule generic_arg_tail = COMMA type_ref
rule fn_type = KW_FN LPAREN param_type_list RPAREN ARROW type_ref
rule map_type = KW_MAP LBRACK type_ref COMMA type_ref RBRACK
rule set_type = KW_SET LBRACK type_ref RBRACK
rule list_type = KW_LIST LBRACK type_ref RBRACK
rule param_type_list = type_ref param_type_tail* |
rule param_type_tail = COMMA type_ref
rule type_atom = KW_INT | KW_CHAR | KW_VOID | KW_STRING | KW_BOOL | KW_UINT | KW_GENERATOR | KW_VAR | IDENT
rule pointer_part = STAR
rule array_part = LBRACK expression_opt RBRACK
rule expression_opt = expression |

rule statement = base_statement statement_suffix
rule statement_suffix = SEMI |
rule base_statement = if_stmt | else_stmt | while_stmt | switch_stmt | case_stmt | for_stmt | return_stmt | yield_stmt | break_stmt | continue_stmt | pass_stmt | debugger_stmt | local_decl | expression_stmt | block
rule if_stmt = KW_IF paren_expression_opt block
rule switch_stmt = KW_SWITCH paren_expression_opt block
rule case_stmt = KW_CASE expression case_value_tail* block | KW_DEFAULT block
rule case_value_tail = COMMA expression
rule else_stmt = KW_ELSE if_stmt | KW_ELSE block
rule while_stmt = KW_WHILE paren_expression_opt block
rule for_stmt = KW_FOR for_binding for_binding_tail KW_IN expression block
rule for_binding = type_ref IDENT | IDENT
rule for_binding_tail = COMMA for_binding | 
rule return_stmt = KW_RETURN expression_opt
rule yield_stmt = KW_YIELD expression
rule break_stmt = KW_BREAK
rule continue_stmt = KW_CONTINUE
rule pass_stmt = KW_PASS
rule debugger_stmt = KW_DEBUGGER
rule local_decl = type_ref name_token decl_suffix local_suffix
rule local_suffix = ASSIGN expression | 
rule expression_stmt = expression

rule paren_expression_opt = LPAREN expression RPAREN | expression
rule expression = assignment
rule assignment = binary_expr assign_tail*
rule assign_tail = gap_many ASSIGN gap_many assignment
rule binary_expr = unary_expr binary_tail*
rule binary_tail = gap_many binary_op gap_many unary_expr
rule binary_op = OR_OR | AND_AND | EQ_EQ | BANG_EQ | LT_EQ | GT_EQ | LT | GT | KW_IN | SHIFT_LEFT | SHIFT_RIGHT | PLUS | MINUS | STAR | SLASH | PERCENT | AMP | PIPE
rule gap_many = gap_item gap_many |
rule gap_item = NEWLINE tab_prefix | NEWLINE
rule unary_expr = unary_op unary_expr | postfix_expr
rule unary_op = BANG | MINUS | PLUS | AMP | STAR
rule postfix_expr = primary_expr postfix_tail*
rule postfix_tail = LPAREN arg_list RPAREN | DOT name_token | LBRACK type_ref generic_arg_tail* RBRACK | LBRACK expression_opt slice_tail RBRACK
rule slice_tail = COLON expression_opt |
rule arg_list = expression arg_tail* |
rule arg_tail = COMMA expression
rule primary_expr = NUMBER | STRING | CHAR_LITERAL | cast_expr | new_expr | grouped_expr | range_expr | hash_literal | name_token
rule hash_literal = map_literal | set_literal | list_literal
rule map_literal = map_type LBRACE map_literal_entries RBRACE
rule map_literal_entries = map_literal_entry map_literal_tail* |
rule map_literal_tail = COMMA map_literal_entry | COMMA
rule map_literal_entry = expression COLON expression
rule set_literal = set_type LBRACE set_literal_entries RBRACE
rule set_literal_entries = expression set_literal_tail* |
rule set_literal_tail = COMMA expression | COMMA
rule list_literal = list_type LBRACE list_literal_entries RBRACE
rule list_literal_entries = expression list_literal_tail* |
rule list_literal_tail = COMMA expression | COMMA
rule grouped_expr = LPAREN expression RPAREN
rule cast_expr = KW_CAST LPAREN type_ref COMMA expression RPAREN
rule new_expr = KW_NEW type_ref new_tail
rule new_tail = LPAREN arg_list RPAREN | LBRACK expression RBRACK |
rule range_expr = KW_RANGE LPAREN arg_list RPAREN | KW_RANGE expression range_tail*
rule range_tail = COMMA expression
