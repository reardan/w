#!/bin/sh
# Bootstrap the W-native build executor (tools/wexec.w) and forward to it.
#
# This is the only shell in the W-native build path: the pinned seed ./w
# compiles the compiler, the compiler compiles the executor, and everything
# after that is described by build.json and run by bin/wexec.
#
# The seed compiles only happen when bin/wexec does not exist yet. A warm
# tree instead runs the manifest's cached 'wv2' and 'wexec' targets, which
# rebuild the compiler and the executor only when their content hashes say
# the sources changed (see the caching notes in tools/wexec.w), and then
# executes the up-to-date executor. 'rm -rf bin' resets everything.
#
#   ./wbuild tests            run the ported test suite
#   ./wbuild verify           self-host fixpoint check
#   ./wbuild --list           show every target in build.json
#   ./wbuild -f m.json name   use another manifest
#   ./wbuild test_changed     build/run the targets touched by the
#                             working tree's diff against HEAD
#   ./wbuild test_changed --keep-going   same, forwarding extra flags
#                             (bin/wexec's --keep-going, -j N, ...) to
#                             the run
#   ./wbuild path/to/file.w   compile (and, for a *_test.w file, run)
#                             that file directly: the manifest target
#                             that already compiles it if there is one,
#                             otherwise a cached ad-hoc compile
#                             (issue #323 stage 1; see tools/wexec.w)
#   ./wbuild x64 path/to/file.w   same, with a target-selector prefix
set -e
cd "$(dirname "$0")"
mkdir -p bin
# Bootstrap seeds are not committed; a missing seed binary is downloaded
# from GitHub Releases per its pin in ./SEEDS and checked against the
# pinned sha256. A seed that is present but differs from its pin (a local
# './wbuild update' promotion, or a stale download after a SEEDS bump) is
# used as-is, with a notice. See docs/release.md.
seed_sha256() {
	if command -v sha256sum >/dev/null 2>&1; then
		sha256sum "$1" | cut -d' ' -f1
	else
		shasum -a 256 "$1" | cut -d' ' -f1
	fi
}
ensure_seed() {
	seed="$1"
	set -- $(awk -v f="$seed" '$1 == f { print $2, $3, $4 }' SEEDS)
	if [ -z "$3" ]; then
		echo "wbuild: no SEEDS entry for '$seed'" >&2
		exit 1
	fi
	if [ ! -f "$seed" ]; then
		echo "wbuild: downloading seed $seed from release $1" >&2
		url="https://github.com/reardan/w/releases/download/$1/$2"
		if command -v curl >/dev/null 2>&1; then
			curl -fsSL -o "$seed.download" "$url"
		else
			wget -qO "$seed.download" "$url"
		fi
		if [ "$(seed_sha256 "$seed.download")" != "$3" ]; then
			rm -f "$seed.download"
			echo "wbuild: seed $seed does not match the sha256 pinned in SEEDS; refusing to run it" >&2
			exit 1
		fi
		chmod +x "$seed.download"
		# mv lands the seed on a fresh inode (macOS vnode signature cache).
		mv -f "$seed.download" "$seed"
	elif [ "$(seed_sha256 "$seed")" != "$3" ]; then
		echo "wbuild: note: $seed differs from its SEEDS pin (local promotion or stale seed; rm $seed to re-download)" >&2
	fi
}
# On macOS the Linux seed ./w cannot run; bootstrap a native Mach-O
# executor from the pinned arm64_darwin seed instead. The seed and
# every stage self-sign via macho_sign.w; fresh inodes (cp + mv) avoid
# the vnode signature-cache gotcha. A warm tree refreshes through the
# manifest's cached 'wexec_darwin' target, then runs bin/wexec_darwin;
# only the darwin targets work here — everything else in build.json
# runs Linux binaries.
if [ "$(uname -s)" = "Darwin" ]; then
	ensure_seed w_darwin
	if [ ! -x bin/wexec_darwin ]; then
		./w_darwin arm64_darwin w.w -o bin/wv2_darwin_raw
		cp bin/wv2_darwin_raw bin/wv2_darwin.new
		mv -f bin/wv2_darwin.new bin/wv2_darwin
		bin/wv2_darwin arm64_darwin tools/wexec.w -o bin/wexec_darwin_raw
		cp bin/wexec_darwin_raw bin/wexec_darwin.new
		mv -f bin/wexec_darwin.new bin/wexec_darwin
	fi
	./bin/wexec_darwin wexec_darwin >/dev/null
	exec ./bin/wexec_darwin "$@"
fi
ensure_seed w
if [ ! -x bin/wexec ]; then
	./w w.w -o bin/wv2
	./bin/wv2 tools/wexec.w -o bin/wexec
fi
if [ "$1" = "test_changed" ]; then
	shift
	# Flags left over after 'test_changed' (e.g. --keep-going) are kept in
	# "$@" and handed to the final './wbuild' invocation below as its
	# leading arguments, ahead of the target names xargs appends from
	# bin/wtest's selection; that call falls through to 'exec ./bin/wexec
	# "$@"' at the bottom of this script, and bin/wexec parses its flags
	# regardless of where they fall in argv, so they reach wexec either
	# way. With no extra flags "$@" expands to nothing and this is exactly
	# the previous pipeline.
	./bin/wexec wv2 wexec wtest >/dev/null
	# Selection baseline: the working tree's diff against HEAD. After a
	# commit that diff is empty, which used to select nothing and exit 0
	# silently; fall back to the branch's diff against its merge-base
	# with origin/main (guarded: no origin/main, no fallback) so a
	# just-committed change still selects its targets.
	base=HEAD
	changed="$(git diff --name-only HEAD)"
	if [ -z "$changed" ] && base_commit="$(git merge-base origin/main HEAD 2>/dev/null)"; then
		echo "wbuild: working tree matches HEAD; selecting from 'git diff $base_commit HEAD' (merge-base with origin/main)" >&2
		base="$base_commit"
		changed="$(git diff --name-only "$base" HEAD)"
	fi
	# The baseline build.json lets bin/wtest scope a manifest diff that
	# only adds/removes generated leaf test targets to those targets
	# instead of the whole 'tests' umbrella (tools/test_map.w). --available
	# drops targets this environment cannot run (missing qemu/wine/...) so
	# 'test_changed's selection is always runnable as printed.
	if git show "$base:build.json" >bin/.wtest_base_manifest.json 2>/dev/null; then
		printf '%s\n' "$changed" | ./bin/wtest changed --available --base-manifest bin/.wtest_base_manifest.json | xargs -r ./wbuild "$@"
	else
		printf '%s\n' "$changed" | ./bin/wtest changed --available | xargs -r ./wbuild "$@"
	fi
	exit 0
fi
./bin/wexec wv2 wexec >/dev/null
exec ./bin/wexec "$@"
